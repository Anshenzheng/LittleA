# ==========================================
# 1. 通用/IDE 配置
# ==========================================
.idea/
.vscode/
*.swp
*.bak
*.tmp
.DS_Store
Thumbs.db

# ==========================================
# 2. 后端配置 (Java/Maven/Spring Boot)
# ==========================================
# 编译后的类文件
server/**/*.class
server/**/target/
server/**/bin/

# 日志文件
server/**/logs/
server/**/*.log

# Maven 属性文件
server/.mvn/wrapper/maven-wrapper.jar
server/release.properties
server/pom.xml.tag
server/pom.xml.releaseBackup
server/pom.xml.backup
server/pom.xml.versionsBackup

# Gradle 缓存
server/.gradle/
server/build/

# ==========================================
# 3. 前端配置 (Node/Angular)
# ==========================================
# 依赖
client/node_modules/
client/dist/
client/.angular/

# 日志与缓存
client/*.log
client/npm-debug.log*
client/yarn-debug.log*
client/yarn-error.log*
client/.eslintcache
client/.cache/

# 单元测试与覆盖率
client/coverage/
client/.nyc_output/

# 环境变量 (包含敏感信息)
client/.env
client/.env.*
!client/.env.example

